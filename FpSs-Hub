    KS:CreateSocialButton({ Type = "Discord", Link = "https://discord.gg/TsN6qyWCTv", Order = 1 })

    KS:CreateButton({
        Description = "✅ Verify Key",
        Callback = function()
            if KS:GetText() == VALID_KEY then
