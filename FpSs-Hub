local function SaveKey(k) pcall(function() writefile(KEY_FILE, k) end) end
local function LoadKey()
    local ok, v = pcall(function() return isfile(KEY_FILE) and readfile(KEY_FILE) or "" end)
    return (ok and v) or ""
end

